# ------------------------------------------------------------------
# Unit 20 — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# ------------------------------------------------------------------

# Supabase ----------------------------------------------------------
# Shared project used by the All Ears Crew CRM (project ref abqkmovvgkrdunyrqhfp).
# URL looks like https://abqkmovvgkrdunyrqhfp.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email) -------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=studio@unit20.nz
RESEND_REPLY_TO=studio@unit20.nz

# Admin -------------------------------------------------------------
# Only this email may access /admin (enforced in middleware).
ADMIN_EMAIL=

# Site --------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://unit20.nz
NEXT_PUBLIC_BUSINESS_PHONE=

# Analytics ---------------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Cron --------------------------------------------------------------
# Shared secret checked on /api/cron/* via Authorization: Bearer <secret>
CRON_SECRET=

# Booking-paid DB webhook ------------------------------------------
# Shared secret for the Supabase Database Webhook that fires on bookings UPDATE
# and hits POST /api/hooks/booking-paid. Configure the webhook to send
# `Authorization: Bearer <BOOKING_HOOK_SECRET>`. This is the ONLY trigger for
# the access-instructions email, so it fires whether payment_status was set by
# the Xero webhook below or manually from the crew Studio tab.
BOOKING_HOOK_SECRET=

# Xero payment webhook ---------------------------------------------
# Signing key from the Xero developer portal webhook config. Used to verify the
# x-xero-signature HMAC-SHA256 of the raw request body on POST /api/webhooks/xero.
XERO_WEBHOOK_KEY=
# Xero Custom Connection (OAuth2 client-credentials, machine-to-machine).
# Create a Custom Connection app in the Xero developer portal for the studio's
# organisation; it yields a client id/secret scoped to a single tenant.
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# The organisation's tenant id (GET https://api.xero.com/connections after first
# auth, or shown in the Custom Connection). Sent as the Xero-tenant-id header.
XERO_TENANT_ID=
